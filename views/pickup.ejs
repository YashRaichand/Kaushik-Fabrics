<%- include('partials/header') %>
<section class="px-6 md:px-12 py-12 max-w-3xl mx-auto">
  <h1 class="font-display text-3xl font-bold mb-8">Book a Pickup</h1>

  <% if (error) { %><div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm"><%= error %></div><% } %>
  <% if (success) { %><div class="bg-green-50 text-green-700 px-4 py-3 rounded-lg mb-4 text-sm"><%= success %></div><% } %>

  <% if (garments.length === 0) { %>
    <p class="text-sm text-[#8a8a80]">No pending items. <a href="/sell" class="accent">List some clothes first →</a></p>
  <% } else { %>
    <form method="POST" action="/pickup" class="bg-white rounded-2xl p-6 shadow-sm space-y-4 text-sm">
      <div>
        <h3 class="font-semibold mb-3">Select items for pickup</h3>
        <% garments.forEach(function(g) { %>
          <label class="flex items-center gap-2 py-1">
            <input type="checkbox" name="garment_ids" value="<%= g.id %>">
            <span class="capitalize"><%= g.category %></span> · <%= g.material %> · Grade <%= g.condition_grade %> · ₹<%= formatINR(g.price) %>
          </label>
        <% }) %>
      </div>
      <input type="text" name="line1" placeholder="Address line" required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
      <div class="flex gap-3">
        <input type="text" name="city" placeholder="City" required class="w-1/2 px-3 py-2 rounded-lg border border-[#ddd4c2]">
        <input type="text" name="pincode" placeholder="Pincode" required class="w-1/2 px-3 py-2 rounded-lg border border-[#ddd4c2]">
      </div>
      <input type="datetime-local" name="scheduled_at" required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
      <button type="submit" class="w-full py-2.5 rounded-full btn-primary font-medium">Schedule Pickup</button>
    </form>
  <% } %>
</section>
<%- include('partials/footer') %>
