<%- include('partials/header') %>
<section class="px-6 md:px-12 py-16 max-w-3xl mx-auto">
  <h1 class="font-display text-3xl font-bold mb-2 text-center">Sell Your Clothes</h1>
  <p class="text-center text-[#6b6b63] mb-10">Fill the form, or just describe what you have.</p>

  <% if (error) { %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-6 text-sm"><%= error %></div>
  <% } %>

  <% if (quote && !quote.nlp) { %>
    <div class="bg-[#eef4ee] border border-[#cfe0cf] rounded-2xl p-6 mb-10">
      <% if (quote.guest) { %>
        <h3 class="font-semibold mb-2">💰 Your Instant Quote: ₹<%= formatINR(quote.payout) %></h3>
        <p class="text-sm text-[#4a4a42]">Assessed value: ₹<%= formatINR(quote.assessedValue) %></p>
      <% } else { %>
        <h3 class="font-semibold mb-2">✅ Item Listed — Estimated Payout: ₹<%= formatINR(quote.payout) %></h3>
        <p class="text-sm text-[#4a4a42]">Assessed value: ₹<%= formatINR(quote.assessedValue) %> · Green Points earned: <%= quote.points %></p>
      <% } %>
      <% if (quote.images && quote.images.length > 0) { %>
        <div class="flex gap-2 mt-3 flex-wrap">
          <% quote.images.forEach(function(img) { %>
            <img src="<%= img %>" alt="Uploaded garment photo" class="w-20 h-20 object-cover rounded-lg border border-[#cfe0cf]">
          <% }) %>
        </div>
      <% } %>
      <details class="mt-3 text-sm text-[#6b6b63]">
        <summary class="cursor-pointer font-medium">Price breakdown</summary>
        <pre class="mt-2 bg-white p-3 rounded-lg overflow-x-auto text-xs"><%= JSON.stringify(quote.breakdown, null, 2) %></pre>
      </details>
      <% if (quote.guest) { %>
        <a href="/signup" class="inline-block mt-4 px-5 py-2 rounded-full btn-primary text-sm">Create Free Account to Lock In This Price →</a>
        <p class="text-xs text-[#8a8a80] mt-2">Your item details carry over automatically — no need to fill this in again. You can add photos once you're signed in.</p>
      <% } else { %>
        <a href="/pickup" class="inline-block mt-4 px-5 py-2 rounded-full btn-primary text-sm">Book a Pickup →</a>
      <% } %>
    </div>
  <% } %>

  <% if (quote && quote.nlp) { %>
    <div class="bg-[#eef4ee] border border-[#cfe0cf] rounded-2xl p-6 mb-10">
      <h3 class="font-semibold mb-3"><%= quote.guest ? '💰 Your Instant Quote' : '✅' %> We understood <%= quote.created.length %> item type(s):</h3>
      <ul class="text-sm space-y-1">
        <% quote.created.forEach(function(item) { %>
          <li><%= item.quantity %> × <%= item.category %> (<%= item.material %>) — estimated ₹<%= formatINR(item.price) %></li>
        <% }) %>
      </ul>
      <% if (quote.guest) { %>
        <a href="/signup" class="inline-block mt-4 px-5 py-2 rounded-full btn-primary text-sm">Create Free Account to Lock In This Price →</a>
        <p class="text-xs text-[#8a8a80] mt-2">Your items carry over automatically — no need to describe them again.</p>
      <% } else { %>
        <a href="/pickup" class="inline-block mt-4 px-5 py-2 rounded-full btn-primary text-sm">Book a Pickup →</a>
      <% } %>
    </div>
  <% } %>

  <div class="grid md:grid-cols-2 gap-8">
    <div class="bg-white rounded-2xl p-6 shadow-sm">
      <h3 class="font-semibold mb-4">Structured Form</h3>
      <form method="POST" action="/sell" enctype="multipart/form-data" class="space-y-3 text-sm">
        <div>
          <label class="block text-xs font-medium text-[#6b6b63] mb-1">Photos (up to <%= maxFiles %>, JPEG/PNG/WEBP, 3MB each)</label>
          <input type="file" name="images" accept="image/jpeg,image/png,image/webp" multiple class="w-full text-xs px-3 py-2 rounded-lg border border-[#ddd4c2] bg-white">
        </div>
        <select name="category" required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
          <option value="">Category</option>
          <option>jeans</option><option>shirt</option><option>t-shirt</option>
          <option>kurti</option><option>kurta</option><option>saree</option><option>dress</option>
          <option>jacket</option><option>sweater</option><option>sweatshirt</option>
          <option>trousers</option><option>skirt</option>
        </select>
        <input type="text" name="brand" placeholder="Brand (optional)" class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
        <select name="brand_tier" class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
          <option value="standard">Standard brand</option>
          <option value="mid">Mid-tier brand</option>
          <option value="premium">Premium brand</option>
          <option value="unbranded">Unbranded</option>
        </select>
        <select name="material" required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
          <option value="">Material</option>
          <option>cotton</option><option>denim</option><option>polyester</option>
          <option>wool</option><option>silk</option><option>linen</option><option>blend</option>
        </select>
        <select name="condition_grade" required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
          <option value="A">A — Like new</option>
          <option value="B" selected>B — Good</option>
          <option value="C">C — Worn / faded</option>
          <option value="D">D — Damaged</option>
        </select>
        <input type="number" step="0.1" min="0.1" name="weight_kg" placeholder="Weight (kg)" required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
        <select name="gender" class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
          <option value="">Gender</option>
          <option>men</option><option>women</option><option>kids</option><option>unisex</option>
        </select>
        <input type="text" name="size" placeholder="Size" class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
        <input type="number" name="quantity" placeholder="Quantity" value="1" min="1" class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]">
        <textarea name="description" placeholder="Notes (optional)" class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]"></textarea>
        <button type="submit" class="w-full py-2.5 rounded-full btn-primary font-medium">Get Quote</button>
      </form>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm">
      <h3 class="font-semibold mb-4">Just Describe It</h3>
      <form method="POST" action="/sell/nlp" class="space-y-3 text-sm">
        <textarea name="description" rows="6" placeholder='e.g. "I have 6 old jeans and 3 cotton shirts, jeans are a bit torn"' required class="w-full px-3 py-2 rounded-lg border border-[#ddd4c2]"></textarea>
        <button type="submit" class="w-full py-2.5 rounded-full font-medium border border-[#1B2B22]">Parse & Get Quote</button>
      </form>
      <p class="text-xs text-[#8a8a80] mt-3">Our NLP engine extracts quantity, category, material, and condition automatically.</p>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
