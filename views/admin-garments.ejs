<%- include('partials/header') %>
<section class="px-6 md:px-12 py-12 max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-1 flex-wrap gap-2">
    <h1 class="font-display text-3xl font-bold">All Submissions</h1>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-[#8a8a80]">
        <span class="w-2 h-2 rounded-full bg-[#7A9E7E] live-dot"></span>
        <span id="live-updated-label">Live · updated just now</span>
      </div>
      <a href="/admin" class="text-sm accent">← Back to Admin</a>
    </div>
  </div>
  <p class="text-sm text-[#8a8a80] mb-8">Every item anyone has ever listed - structured form or free-text description - whether or not they've booked a pickup yet. Most recent first, up to 200.</p>

  <% if (garments.length === 0) { %>
    <div class="bg-white rounded-2xl p-8 text-center text-sm text-[#8a8a80]">No submissions yet.</div>
  <% } %>

  <div id="garments-list" data-baseline-id="<%= latestGarmentId %>" class="space-y-4">
    <% garments.forEach(function(g) { %>
      <div class="bg-white rounded-2xl p-5 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
          <div>
            <div class="font-semibold capitalize"><%= g.category %> · <%= g.material %> · Grade <%= g.condition_grade %></div>
            <div class="text-xs text-[#8a8a80] mt-0.5"><%= g.customer_name %> · 📞 <%= g.customer_phone || 'No phone' %> · ✉️ <%= g.customer_email %></div>
            <div class="text-xs text-[#8a8a80] mt-0.5"><%= formatIST(g.created_at) %> · Status: <span class="font-medium"><%= g.status.replace('_',' ') %></span></div>
          </div>
          <div class="text-right">
            <div class="font-semibold">₹<%= formatINR(g.price) %></div>
            <div class="text-xs text-[#8a8a80]"><%= g.weight_kg %>kg · Qty <%= g.quantity %></div>
          </div>
        </div>

        <% if (g.description) { %>
          <div class="bg-[#f7f3ec] rounded-lg p-3 mt-2 text-sm text-[#4a4a42] italic">"<%= g.description %>"</div>
        <% } %>

        <div class="mt-3 pt-3 border-t border-[#f0ece1] text-xs">
          <% if (g.pickup_id) { %>
            <div class="flex items-center gap-2 text-[#4a4a42]">
              <span class="inline-block px-2 py-0.5 rounded-full bg-[#eef4ee] text-[#3d5a41] font-medium">Pickup #<%= g.pickup_id %> · <%= g.pickup_status %></span>
              <span>📍 <%= g.line1 %>, <%= g.city %> <%= g.pincode %></span>
              <span>🕒 <%= formatWallClock(g.scheduled_at) %> (India time)</span>
            </div>
          <% } else { %>
            <span class="inline-block px-2 py-0.5 rounded-full bg-[#f2ede2] text-[#8a8a80] font-medium">No pickup booked yet - no address on file</span>
          <% } %>
        </div>

        <% if (g.images && g.images.length > 0) { %>
          <div class="flex gap-2 mt-3 flex-wrap">
            <% g.images.forEach(function(img) { %>
              <img src="<%= img %>" alt="<%= g.category %>" class="w-16 h-16 object-cover rounded-lg border border-[#eee]">
            <% }) %>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
</section>
<script src="/js/admin-live.js"></script>
<%- include('partials/footer') %>
