<%- include('partials/header') %>
<section class="px-6 md:px-12 py-12 max-w-5xl mx-auto">
  <h1 class="font-display text-3xl font-bold mb-8">Welcome back, <%= user.name %></h1>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <div class="text-xs text-[#8a8a80] mb-1">Wallet Balance</div>
      <div class="font-display text-2xl font-bold">₹<%= formatINR(wallet.balance) %></div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <div class="text-xs text-[#8a8a80] mb-1">Green Points</div>
      <div class="font-display text-2xl font-bold"><%= points %></div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <div class="text-xs text-[#8a8a80] mb-1">Water Saved</div>
      <div class="font-display text-2xl font-bold"><%= impact.waterLitersSaved.toLocaleString() %>L</div>
    </div>
    <div class="bg-white rounded-2xl p-5 shadow-sm">
      <div class="text-xs text-[#8a8a80] mb-1">CO₂ Saved</div>
      <div class="font-display text-2xl font-bold"><%= impact.co2KgSaved %>kg</div>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-8">
    <div>
      <h2 class="font-semibold mb-4">Your Garments</h2>
      <div class="space-y-2">
        <% garments.forEach(function(g) { %>
          <div class="bg-white rounded-xl p-4 shadow-sm flex justify-between items-center text-sm">
            <div>
              <div class="font-medium capitalize"><%= g.category %> · <%= g.material %></div>
              <div class="text-xs text-[#8a8a80]">Grade <%= g.condition_grade %> · <%= g.status.replace('_',' ') %></div>
            </div>
            <div class="font-semibold">₹<%= formatINR(g.price) %></div>
          </div>
        <% }) %>
        <% if (garments.length === 0) { %>
          <p class="text-sm text-[#8a8a80]">No garments listed yet. <a href="/sell" class="accent">Sell your first item →</a></p>
        <% } %>
      </div>
    </div>

    <div>
      <h2 class="font-semibold mb-4">Pickup History</h2>
      <div class="space-y-2">
        <% pickups.forEach(function(p) { %>
          <div class="bg-white rounded-xl p-4 shadow-sm text-sm">
            <div class="font-medium">Pickup #<%= p.id %> — <%= p.status %></div>
            <div class="text-xs text-[#8a8a80]"><%= formatWallClock(p.scheduled_at) %> (India time)</div>
            <% if (p.status === 'scheduled') { %>
              <div class="text-xs text-[#8a8a80] mt-2">Waiting for our team to collect and confirm your items.</div>
            <% } %>
          </div>
        <% }) %>
        <% if (pickups.length === 0) { %>
          <p class="text-sm text-[#8a8a80]">No pickups yet.</p>
        <% } %>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
