<%- include('partials/header') %>
<section class="px-6 md:px-12 py-16 max-w-md mx-auto">
  <h1 class="font-display text-3xl font-bold mb-2 text-center">Welcome back</h1>
  <p class="text-center text-sm text-[#8a8a80] mb-6">Log in to manage your pickups and wallet.</p>

  <% if (errors.general === 'suggest_signup') { %>
    <div class="bg-amber-50 border border-amber-200 text-amber-800 px-4 py-3 rounded-lg mb-4 text-sm flex items-center justify-between gap-3 flex-wrap">
      <span>No account found for this email. First time here?</span>
      <a href="/signup?email=<%= encodeURIComponent(old.email) %>" class="font-semibold underline whitespace-nowrap">Create an account →</a>
    </div>
  <% } else if (errors.general === 'server_error') { %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg mb-4 text-sm">Something went wrong on our end. Please try again in a moment.</div>
  <% } %>

  <form method="POST" action="/login" id="login-form" class="space-y-4" novalidate>
    <div>
      <input type="email" name="email" value="<%= old.email %>" placeholder="Email" autocomplete="email"
        class="w-full px-4 py-3 rounded-lg border <%= (errors.email && errors.general !== 'suggest_signup') ? 'border-red-400' : 'border-[#ddd4c2]' %> focus:outline-none focus:ring-2 focus:ring-[#1B2B22]/20">
      <% if (errors.email && errors.general !== 'suggest_signup') { %><p class="text-xs text-red-600 mt-1"><%= errors.email %></p><% } %>
    </div>
    <div class="relative">
      <input type="password" name="password" id="login-password" placeholder="Password" autocomplete="current-password"
        class="w-full px-4 py-3 pr-16 rounded-lg border <%= errors.password ? 'border-red-400' : 'border-[#ddd4c2]' %> focus:outline-none focus:ring-2 focus:ring-[#1B2B22]/20">
      <button type="button" data-toggle="login-password" class="toggle-password absolute right-3 top-3 text-xs font-medium text-[#8a8a80]">Show</button>
      <% if (errors.password) { %><p class="text-xs text-red-600 mt-1"><%= errors.password %></p><% } %>
    </div>
    <label class="flex items-center gap-2 text-sm text-[#6b6b63]">
      <input type="checkbox" name="remember" class="rounded"> Keep me logged in for 30 days
    </label>
    <button type="submit" class="w-full py-3 rounded-full btn-primary font-medium">Log In</button>
  </form>
  <p class="text-sm text-center mt-4 text-[#6b6b63]">New to Fabrique? <a href="/signup" class="accent font-medium">Create an account</a></p>
</section>
<script src="/js/auth.js"></script>
<%- include('partials/footer') %>
